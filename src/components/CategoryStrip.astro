---
import { categoryIcon } from "../lib/icons.js";
const { categories = [] } = Astro.props;
const base = import.meta.env.BASE_URL;
const items = categories.slice(0, 6);
---
<div class="category-wrap container" aria-label="Product categories">
  <div class="category-strip">
    {items.map((cat) => (
      <a href={`${base}catalog/?cat=${cat.slug || cat.id}`}>
        <span class="ico" set:html={categoryIcon(cat.name, 30)} />
        <strong>{cat.name}</strong>
      </a>
    ))}
  </div>
</div>
<style>
  .category-wrap { position: relative; z-index: 8; margin-top: -38px; }
  .category-strip { display: grid; grid-template-columns: repeat(6,1fr); padding: 0 18px; border: 1px solid #eadcc7; background: #fff; box-shadow: 0 12px 30px rgba(61,44,24,.08); }
  a { display: grid; min-width: 120px; height: 86px; place-items: center; padding: 12px 8px; border-right: 1px solid #eee4d5; text-align: center; transition: background-color .18s, color .18s; }
  a:last-child { border-right: 0; }
  a:hover { background:#fff7e8; color:#9a5700; }
  .ico { display: grid; place-items: center; color: var(--brand); } .ico :global(svg) { width: 30px; height: 30px; } strong { font-size: .8rem; margin-top: 4px; }
  @media(max-width:760px){.category-wrap{margin-top:-28px}.category-strip{display:flex;overflow:auto;padding:0 10px;scroll-padding-inline:10px;scroll-snap-type:x mandatory}.category-strip a{flex:0 0 120px;height:82px;scroll-snap-align:start}}
</style>
