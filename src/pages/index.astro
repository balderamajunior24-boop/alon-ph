---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import CategoryStrip from "../components/CategoryStrip.astro";
import CardGrid from "../components/CardGrid.astro";
import HowItWorks from "../components/HowItWorks.astro";
import PhotoboothPromo from "../components/PhotoboothPromo.astro";
import CollabBanner from "../components/CollabBanner.astro";
import { getCatalog } from "../lib/catalog.js";
import { uiIcon } from "../lib/icons.js";

const { categories, products, home } = await getCatalog();
const base = import.meta.env.BASE_URL;

// Featured items: those flagged featured, else the first few.
const featuredPool = products.filter((p) => p.featured);
const featured = (featuredPool.length ? featuredPool : products).slice(0, 6);
const topCategories = categories.slice(0, 6);
---
<BaseLayout home={home}>
  <Hero home={home} />
  {topCategories.length > 0 && <CategoryStrip categories={topCategories} />}
  {featured.length > 0 && (
    <section class="section featured">
      <div class="container">
        <div class="section-heading">
          <div>
            <h2 class="section-title">{home.featured_title}</h2>
            <p class="section-subtitle">{home.featured_subtitle}</p>
          </div>
          <a class="text-link" href={`${base}catalog/`}>View All Catalog <span set:html={uiIcon("arrowRight", 19)} /></a>
        </div>
        <CardGrid products={featured} />
      </div>
    </section>
  )}
  <HowItWorks />
  <PhotoboothPromo home={home} />
  <CollabBanner home={home} />
</BaseLayout>
<style>.featured { padding-top: 42px; } @media(min-width:900px){.featured{padding-top:48px}}</style>
