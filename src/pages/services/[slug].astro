---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCatalog } from "../../lib/catalog.js";
import { placeholderImage, uiIcon } from "../../lib/icons.js";

export async function getStaticPaths() {
  const { services } = await getCatalog();
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const { home, services } = await getCatalog();
const base = import.meta.env.BASE_URL;

let images = [service.image, ...service.gallery].filter(Boolean);
if (images.length === 0) images = [placeholderImage(`${service.tags} ${service.name} service`, service.name)];

const others = services.filter((s) => s.slug !== service.slug).slice(0, 4);
---
<BaseLayout home={home} title={`${service.name} | ALOK Services`} description={service.desc}>
  <div class="container detail">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href={`${base}services/`}>Services</a><span>/</span><b>{service.name}</b>
    </nav>

    <div class="detail-grid">
      <section class="gallery" aria-label={`${service.name} images`}>
        <div class="main">
          <button id="open" class="open" type="button" aria-label="Enlarge image">
            <img id="main-image" src={images[0]} alt={service.name} />
            {images.length > 1 && <span class="hint">View larger</span>}
          </button>
        </div>
        {images.length > 1 && (
          <div class="thumbs">
            {images.map((src, i) => (
              <button class:list={["thumb", { "thumb--active": i === 0 }]} data-src={src} aria-label={`Image ${i + 1}`}>
                <img src={src} alt="" loading="lazy" />
              </button>
            ))}
          </div>
        )}
      </section>

      <section class="info">
        {service.featured && <span class="tag">Featured Service</span>}
        <h1>{service.name}</h1>
        {service.desc && <p class="lead">{service.desc}</p>}
        <div class="panel">
          <p class="panel-note">Share your event date, venue, and guest count. We’ll recommend a package and send a quote.</p>
          <button id="add" class="button button-primary block" data-id={`service:${service.id}`} data-name={service.name}><span set:html={uiIcon("addList", 17)} /> Add to Inquiry List</button>
          <a class="button button-outline block" href={`${base}inquiry/`}>Go to Inquiry List</a>
          <p id="status" class="status" role="status" aria-live="polite"></p>
        </div>
      </section>
    </div>

    {others.length > 0 && (
      <section class="related">
        <h2 class="section-title">Other Services</h2>
        <div class="rel-grid">
          {others.map((s) => (
            <a class="rel-card" href={`${base}services/${s.slug}/`}>
              <div class="rel-img"><img src={s.image || placeholderImage(`${s.tags} ${s.name} service`, s.name)} alt={s.name} loading="lazy" /></div>
              <strong>{s.name}</strong>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>

  <dialog id="lightbox" aria-label={`${service.name} preview`}>
    <button id="close" class="close" type="button" aria-label="Close">×</button>
    <img id="lightbox-img" src={images[0]} alt={`${service.name} enlarged`} />
  </dialog>
</BaseLayout>

<script>
  import { addItem } from "../../scripts/inquiry.js";
  const main = document.querySelector("#main-image");
  const lightboxImg = document.querySelector("#lightbox-img");
  const dialog = document.querySelector("#lightbox");
  const thumbs = [...document.querySelectorAll(".thumb")];

  thumbs.forEach((t) => t.addEventListener("click", () => {
    main.src = t.dataset.src;
    lightboxImg.src = t.dataset.src;
    thumbs.forEach((x) => x.classList.remove("thumb--active"));
    t.classList.add("thumb--active");
  }));

  document.querySelector("#open")?.addEventListener("click", () => dialog?.showModal?.());
  document.querySelector("#close")?.addEventListener("click", () => dialog?.close());
  dialog?.addEventListener("click", (e) => { if (e.target === dialog) dialog.close(); });
  dialog?.addEventListener("close", () => document.querySelector("#open")?.focus());

  const add = document.querySelector("#add");
  add?.addEventListener("click", () => {
    if (add.dataset.busy) return;
    addItem({ id: add.dataset.id, productName: add.dataset.name, variantName: "Service inquiry", qty: 1 });
    add.dataset.busy = "1";
    const original = add.innerHTML;
    add.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 12 4 4L19 6"/></svg> Added to Inquiry';
    document.querySelector("#status").textContent = "Added! Open your inquiry list when ready.";
    setTimeout(() => { add.innerHTML = original; delete add.dataset.busy; }, 1600);
  });
</script>

<style>
  .detail { padding: 22px 0 10px; }
  .crumbs { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 18px; color: var(--muted); font-size: .82rem; }
  .crumbs a:hover { color: var(--brand); }
  .detail-grid { display: grid; grid-template-columns: 1.1fr .9fr; gap: 34px; }
  .main { overflow: hidden; border: 1px solid #f2ddce; border-radius: 18px; background: #fff8f1; }
  .open { display: block; width: 100%; padding: 0; border: 0; background: none; cursor: zoom-in; position: relative; }
  .open img { width: 100%; aspect-ratio: 16/11; object-fit: cover; }
  .hint { position: absolute; right: 12px; bottom: 12px; padding: 5px 10px; border-radius: 999px; background: rgba(0,0,0,.6); color: #fff; font-size: .72rem; opacity: 0; transition: opacity .2s; }
  .open:hover .hint { opacity: 1; }
  .thumbs { display: flex; gap: 10px; overflow-x: auto; margin-top: 12px; }
  .thumb { flex: 0 0 76px; height: 76px; overflow: hidden; padding: 3px; border: 2px solid transparent; border-radius: 12px; background: #fff; cursor: pointer; }
  .thumb img { width: 100%; height: 100%; border-radius: 8px; object-fit: cover; }
  .thumb--active { border-color: var(--brand); }
  .tag { display: inline-block; margin-bottom: 8px; padding: 4px 10px; border-radius: 999px; background: #fff0e4; color: var(--brand); font-size: .72rem; font-weight: 800; }
  .info h1 { margin: 0 0 8px; font-size: clamp(1.5rem,2.5vw,2rem); }
  .lead { margin: 0 0 18px; color: #4d5257; }
  .panel { padding: 20px; border: 1px solid #f5d8c1; border-radius: 16px; background: #fff; display: grid; gap: 12px; }
  .panel-note { margin: 0; color: #57606a; font-size: .9rem; }
  .block { width: 100%; }
  .status { min-height: 1.3em; margin: 0; color: #1c7a4b; font-size: .86rem; }
  .related { margin-top: 46px; }
  .rel-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 14px; margin-top: 18px; }
  .rel-card { padding: 8px; border: 1px solid #ece9e6; border-radius: 12px; background: #fff; text-align: center; }
  .rel-card:hover { box-shadow: 0 8px 18px rgba(76,52,35,.1); }
  .rel-img { overflow: hidden; border-radius: 8px; } .rel-img img { width: 100%; aspect-ratio: 16/10; object-fit: cover; }
  .rel-card strong { display: block; margin-top: 8px; font-size: .82rem; }
  dialog { width: min(960px,94vw); padding: 2.5rem 1rem 1rem; border: 0; border-radius: 1rem; background: #fff; }
  dialog::backdrop { background: rgba(28,16,11,.8); backdrop-filter: blur(4px); }
  dialog img { width: 100%; max-height: 80vh; object-fit: contain; }
  .close { position: absolute; top: .5rem; right: .75rem; width: 40px; height: 40px; border: 0; border-radius: 50%; background: #fff0e6; color: #9b3507; font-size: 1.7rem; cursor: pointer; }
  @media(max-width:860px){ .detail-grid { grid-template-columns: 1fr; } .rel-grid { grid-template-columns: repeat(2,1fr); } }
  @media(max-width:600px){
    .detail { padding-top: 14px; }
    .detail-grid { gap: 22px; }
    .crumbs { margin-bottom: 12px; }
    .panel { padding: 16px; }
    .related { margin-top: 34px; }
    dialog { width: calc(100vw - 24px); padding: 3rem 10px 10px; }
    dialog img { max-height: 72vh; }
  }
</style>
