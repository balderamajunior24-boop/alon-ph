---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import InquiryDrawer from "../components/InquiryDrawer.astro";
const {
  title = "ALON-PH | Customized Event Kits",
  description = "Customized event kits, branded merchandise, giveaways and event support services.",
  home = {},
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ed5209" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 64 64%22><rect width=%2264%22 height=%2264%22 rx=%2214%22 fill=%22%23ed5209%22/><path d=%22M14 46 30 14h9l11 32h-9l-2-7H25l-3 7zm14-15h9l-4-12z%22 fill=%22white%22/></svg>" />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main><slot /></main>
    <Footer home={home} />
    <InquiryDrawer home={home} />
  </body>
</html>
