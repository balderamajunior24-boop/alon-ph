# ALON-PH — environment template
# Copy to `.env` (cp .env.example .env) and fill in. `.env` is git-ignored.
#
# These are read at BUILD time on the server, so the API key never reaches
# the browser (unlike the old plain-JS version).
#
# ---- SHEET_ID ----
# From the sheet URL: .../spreadsheets/d/<SHEET_ID>/edit
SHEET_ID=1RB636xdQL80qJAuapZbtNAlORAfXTFX19eyO_nLsXlg

# ---- SHEET_API_KEY ----
# Use an *API KEY* — NOT an "OAuth 2.0 Client ID". OAuth is for signing in as a
# user; an API key reads public (link-shared) data with no login, which is what
# a static build needs.
#
# Google Cloud Console (https://console.cloud.google.com/):
#   1. APIs & Services -> Library -> search "Google Sheets API" -> Enable.
#   2. APIs & Services -> Credentials -> + Create credentials -> "API key".
#
# On the "Create API key" dialog:
#   - Name: anything (e.g. alon-ph).
#   - Select API restrictions (required): open the dropdown and check
#     "Google Sheets API". (If it's not listed, you skipped step 1 above.)
#   - "Authenticate API calls through a service account": LEAVE UNCHECKED
#     (the sheet is public, so no service account is needed).
#   - Application restrictions: "None" is fine — this key is only used at
#     BUILD time (server-side / CI), never in the browser, so a website/IP
#     restriction doesn't apply.
#   - Click Create, then copy the key (starts with "AIza...").
#
# Also share the sheet: Share -> General access -> "Anyone with the link" -> Viewer.
SHEET_API_KEY=PUT_YOUR_API_KEY_HERE

# Tab names (must match the sheet exactly)
TAB_CATEGORIES=Categories
TAB_PRODUCTS=Products
TAB_VARIANTS=Variants

# Where inquiry emails go (primary/required channel)
INQUIRY_EMAIL=hello@alon-ph.example
